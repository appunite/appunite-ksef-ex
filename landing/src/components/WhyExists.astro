---
import { getLocaleFromUrl, useTranslations } from "../i18n";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---
<section class="py-20 border-b border-[var(--border)]">
  <div class="container-page">
    <div class="grid md:grid-cols-[1fr_1.4fr] gap-12 items-start">
      <div>
        <div class="eyebrow mb-3">{t.why.eyebrow}</div>
        <h2 class="section-h2">{t.why.heading}</h2>
      </div>
      <div class="space-y-5 text-[15px] leading-relaxed text-[var(--muted-foreground)]">
        <p>{t.why.para1}</p>
        <p>{t.why.para2}</p>
      </div>
    </div>
  </div>
</section>
