---
import { getLocaleFromUrl, useTranslations } from "../i18n";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: t.faq.items.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---
<section id="faq" class="py-24 border-b border-[var(--border)]">
  <div class="container-page">
    <div class="max-w-[720px] mb-14">
      <div class="eyebrow mb-3">{t.faq.eyebrow}</div>
      <h2 class="section-h2">{t.faq.heading}</h2>
    </div>

    <div class="max-w-[820px] space-y-0 border-t border-[var(--border)]">
      {t.faq.items.map((item) => (
        <details class="group border-b border-[var(--border)]">
          <summary class="list-none cursor-pointer py-5 flex items-start justify-between gap-6">
            <span class="text-[15px] font-medium text-[var(--foreground)]">{item.q}</span>
            <span class="mt-0.5 text-[var(--muted-foreground)] transition-transform group-open:rotate-45 text-lg leading-none select-none" aria-hidden="true">+</span>
          </summary>
          <p class="pb-6 pr-10 text-[15px] leading-relaxed text-[var(--muted-foreground)]" style="text-wrap: pretty;">
            {item.a}
          </p>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />
