---
import { getLocaleFromUrl, useTranslations } from "../i18n";
import { repoUrl, contactMailto } from "../config";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const plans = [
  {
    plan: t.pricing.selfHost,
    href: repoUrl,
    variant: "ghost" as const,
  },
  {
    plan: t.pricing.enterprise,
    href: contactMailto,
    variant: "primary" as const,
  },
];
---
<section id="self-host" class="py-24 border-b border-[var(--border)]">
  <div class="container-page">
    <div class="max-w-[720px] mb-14">
      <div class="eyebrow mb-3">{t.pricing.eyebrow}</div>
      <h2 class="section-h2 mb-4">{t.pricing.heading}</h2>
      <p class="text-[var(--muted-foreground)] text-lg">{t.pricing.body}</p>
    </div>

    <div class="grid md:grid-cols-2 gap-5 max-w-[760px]">
      {plans.map(({ plan, href, variant }) => (
        <div class="card-flat">
          <div class="text-xs uppercase tracking-wide text-[var(--muted-foreground)] font-medium mb-2">{plan.label}</div>
          <div class="text-3xl font-semibold mb-1">{plan.price}</div>
          <div class="text-sm text-[var(--muted-foreground)] mb-5">{plan.tagline}</div>
          <a
            href={href}
            class={`${variant === "primary" ? "btn-primary" : "btn-ghost border border-[var(--border)]"} w-full justify-center mb-6`}
          >
            {plan.cta}
          </a>
          <ul class="space-y-2.5 text-sm">
            {plan.features.map((f) => (
              <li class="flex gap-2"><span class="text-[var(--brand)]">*</span> {f}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
