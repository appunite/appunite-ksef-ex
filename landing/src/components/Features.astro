---
import { getLocaleFromUrl, useTranslations } from "../i18n";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const icons: Record<keyof typeof t.features, string> = {
  ksefSync: `<path d="M21 12a9 9 0 11-3-6.7L21 8"/><path d="M21 3v5h-5"/>`,
  multiCompany: `<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 10h18M9 4v16"/>`,
  email: `<path d="M4 4h12l4 4v12H4z"/><path d="M8 13h8M8 17h8M8 9h4"/>`,
  ml: `<circle cx="12" cy="12" r="3"/><path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2 2M16.4 16.4l2 2M5.6 18.4l2-2M16.4 7.6l2-2"/>`,
  corrections: `<rect x="8" y="8" width="12" height="12" rx="2"/><path d="M16 8V6a2 2 0 00-2-2H6a2 2 0 00-2 2v8a2 2 0 002 2h2"/>`,
  approval: `<path d="M20 6L9 17l-5-5"/>`,
  payments: `<rect x="3" y="6" width="18" height="12" rx="2"/><circle cx="12" cy="12" r="2"/><path d="M3 10h18"/>`,
  certificate: `<circle cx="12" cy="9" r="5"/><path d="M9 13.5L7 21l5-3 5 3-2-7.5"/>`,
  accountant: `<circle cx="9" cy="8" r="4"/><path d="M2 21a7 7 0 0114 0M18 9v6M15 12h6"/>`,
  perInvoice: `<rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 018 0v4"/>`,
  activity: `<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>`,
  api: `<path d="M8 6l-6 6 6 6M16 6l6 6-6 6M14 4l-4 16"/>`,
};

const order: (keyof typeof t.features)[] = [
  "ksefSync",
  "multiCompany",
  "email",
  "ml",
  "corrections",
  "approval",
  "payments",
  "certificate",
  "accountant",
  "perInvoice",
  "activity",
  "api",
];
---
<section id="features" class="py-24 border-b border-[var(--border)]">
  <div class="container-page">
    <div class="max-w-[720px] mb-14">
      <div class="eyebrow mb-3">{t.featuresSection.eyebrow}</div>
      <h2 class="section-h2 mb-4">{t.featuresSection.heading}</h2>
      <p class="text-[var(--muted-foreground)] text-lg">{t.featuresSection.subhead}</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {order.map((key) => (
        <div class="card-flat">
          <div class="feat-icon mb-4">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" set:html={icons[key]} />
          </div>
          <div class="font-medium mb-1.5">{t.features[key].title}</div>
          <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{t.features[key].body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
