# KSeF Hub — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env

# --- Google OAuth (admin UI login) ---
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Comma-separated list of emails allowed to log in
ALLOWED_EMAILS=your-email@example.com

# --- KSeF API ---
# Test: https://ksef-test.mf.gov.pl
# Production: https://ksef.mf.gov.pl
KSEF_API_URL=https://ksef-test.mf.gov.pl

# --- Gotenberg (PDF generation sidecar) ---
GOTENBERG_URL=http://localhost:3000

# --- Database (only needed for prod, dev uses config/dev.exs defaults) ---
# DATABASE_URL=ecto://postgres:postgres@localhost/ksef_hub_dev

# --- Phoenix (only needed for prod) ---
# SECRET_KEY_BASE=generate-with-mix-phx-gen-secret
# PHX_HOST=your-domain.com
# PORT=4000
# PHX_SERVER=true

# --- Database connection pool (prod only, default: 10) ---
# POOL_SIZE=10

# --- Encryption key for certificate storage (optional, falls back to SECRET_KEY_BASE) ---
# GCP_SECRET_NAME=projects/my-project/secrets/ksef-encryption-key/versions/latest

# --- Ecto IPv6 (set to true if your database requires IPv6) ---
# ECTO_IPV6=false
